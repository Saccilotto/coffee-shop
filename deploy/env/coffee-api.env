# Instalado em /etc/coffee-shop/env pelo hook AfterInstall.
# A revisao "quebrada" da demo de rollback acrescenta COFFEE_FORCE_UNHEALTHY=1
# aqui (scripts/demo-rollback.sh) — nada mais muda entre as duas revisoes.
COFFEE_PLATFORM=iaas
COFFEE_DB_PATH=/opt/coffee-shop/api/data/coffee.db
AWS_DEFAULT_REGION=us-east-1
