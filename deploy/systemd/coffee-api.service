[Unit]
Description=coffee-shop API (FastAPI/uvicorn) - caminho IaaS via CodeDeploy
After=network.target

[Service]
Type=simple
User=coffee
Group=coffee
WorkingDirectory=/opt/coffee-shop/api
EnvironmentFile=-/etc/coffee-shop/env
ExecStart=/opt/coffee-shop/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
